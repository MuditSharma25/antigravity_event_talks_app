# pyenv
#   For a library or app, you might want to share your .python-version if you
#   intend to associate a specific version of Python with this project.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or
#   python versions, Pipfile.lock might be conflictual.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock can be gitignored or not, depending on preference.
#   For applications, it's recommended to commit it.
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is usually committed.
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
#   For virtualenvwrapper:
